APP_NAME="Florist Shop"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost
APP_PORT=8000

# Database
DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite

# Session
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Cache & Queue
CACHE_STORE=file
QUEUE_CONNECTION=sync

# Filesystem
FILESYSTEM_DISK=local

# Mail (for notifications)
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525

# Security
APP_KEY=base64:
BCRYPT_ROUNDS=12

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=debug

# Redis (optional, for production)
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# API Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
